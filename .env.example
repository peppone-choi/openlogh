# ============================================================
# OpenLOGH Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Database ---
DB_NAME=openlogh
DB_USER=openlogh
DB_PASSWORD=openlogh123
DB_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- JWT Secret (CHANGE IN PRODUCTION) ---
# Must be at least 256 bits (32+ characters) for HS256
JWT_SECRET=openlogh-jwt-secret-key-must-be-at-least-256-bits-long-for-hs256

# --- Admin Bootstrap ---
# Creates an admin user on first startup
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_LOGIN_ID=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
ADMIN_DISPLAY_NAME=관리자
ADMIN_GRADE=5

# --- Docker ---
# Tag for pre-built images (used in production)
TAG=latest

# HTTP port exposed by nginx
HTTP_PORT=80

# Docker image prefix for game-app containers spawned by gateway
DOCKER_IMAGE_PREFIX=ghcr.io/peppone-choi/openlogh-game

# --- Gateway orchestrator tuning (optional) ---
# GATEWAY_RESTORE_ACTIVE_WORLDS=true
# GATEWAY_HEALTH_TIMEOUT_MS=180000
# GATEWAY_RESTORE_MAX_RETRIES=3
# GATEWAY_RESTORE_RETRY_DELAY_MS=30000
